# Upstream MPFR clone — large, cloned per machine.
# Leading slash anchors to repo root; without it the pattern matches
# `mpfr/` at any depth (e.g. `src/internal/mpfr/`) and silently drops
# substrate files. Verified bite: 2026-05-24 — 50→85 session lost 3
# substrate ports for ~12hr before next agent caught it.
/mpfr/

# Runtime / package manager
node_modules/
.bun/
bun.lockb

# Python venv (analysis scripts)
.venv/
__pycache__/
*.pyc

# Build artifacts
dist/
/tmp/

# Compiled golden drivers (regenerated by eval/golden_master/build.sh)
eval/functions/*/golden_driver
eval/golden_master/*.o

# Regenerable goldens (generated from libmpfr per MPFR_VERSION pin)
eval/functions/*/golden.jsonl

# Generated reports
eval/reports/*.png
eval/reports/*.html

# Logs
*.log

# Editor / OS
.DS_Store
.vscode/
.idea/

# Claude Code plugin pollution — Lean4 tooling auto-staged by the
# lean4-theorem-proving plugin's SessionStart hook. Not relevant to
# this TypeScript project. Keep .claude/settings.json which is the
# project-specific hook configuration.
.claude/tools/
.claude/docs/

# Beads / Dolt files (added by bd init)
.dolt/
.beads-credential-key

# NOTE: eval/state.db is intentionally NOT ignored (CLAUDE.md Rule 9).
# The generic `*.db` glob from `bd init` is replaced with explicit paths.
# SQLite WAL sidecars are ephemeral and recreated on demand; never commit them.
eval/state.db-wal
eval/state.db-shm
eval/state.db-journal
